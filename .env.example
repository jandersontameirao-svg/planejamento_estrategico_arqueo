# ─────────────────────────────────────────────────────────────
# .env.example — copie para .env e preencha os valores reais.
# NUNCA commite o .env (já está no .gitignore).
# ─────────────────────────────────────────────────────────────

# ===== OBRIGATÓRIO (app não sobe/funciona sem isso) =====

NODE_ENV=production
PORT=3000

# Segredo para assinar os cookies de sessão (JWT). OBRIGATÓRIO em produção.
# Gere um novo com:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=COLE_UM_SEGREDO_FORTE_AQUI

# Banco MySQL (drizzle/mysql2). Formato:
# mysql://USUARIO:SENHA@HOST:3306/NOME_DO_BANCO
DATABASE_URL=mysql://usuario:senha@localhost:3306/arqueo

# ===== IA (OpenAI) =====
OPENAI_API_KEY=sk-cole-sua-chave-openai
OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_BASE_URL=https://api.openai.com   # default; só mude se usar proxy
# OPENAI_MAX_TOKENS=16384                       # limite de saída

# ===== LOGIN / OAuth (Manus) =====
# Enquanto o login não for substituído, estes vêm da plataforma Manus.
# Sem eles, ninguém consegue autenticar.
OAUTH_SERVER_URL=
VITE_APP_ID=
OWNER_OPEN_ID=

# ===== STORAGE (Manus forge — substituir por Cloudflare R2 depois) =====
# Usado em server/storage.ts para upload de PDFs/planilhas.
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ===== E-MAIL (opcional — notificações) =====
# APP_URL=https://arqueotech.com.br
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# ===== Integração SGC (opcional — deixe desativado se não usar) =====
SGC_ENABLED=false
# SGC_API_BASE_URL=
# SGC_INTERNAL_TOKEN=
# SGC_TIMEOUT_MS=10000
# SGC_PUBLIC_APP_URL=
# VITE_SGC_PUBLIC_APP_URL=

# ===== Integração Organograma (opcional) =====
# ORGANOGRAM_API_BASE_URL=
# ORGANOGRAM_INTERNAL_TOKEN=

# ===== Analytics (opcional — Umami) =====
# VITE_ANALYTICS_ENDPOINT=
# VITE_ANALYTICS_WEBSITE_ID=
